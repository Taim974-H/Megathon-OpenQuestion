# Copy to .env.local and fill in real values. NEVER commit the filled-in file.
# On Vercel, set these in Project Settings -> Environment Variables instead.

# --- PixVerse (ad video generation) ---
# Get a key at https://platform.pixverse.ai/ . Used server-side only.
PIXVERSE_API_KEY=

# --- OpenAI (chat + fallback TTS/transcription) ---
OPENAI_KEY=

# --- ElevenLabs (horse voice TTS) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- SMTP (email transcript export, Gmail) ---
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# --- ffmpeg (optional: end-card stitching) ---
# Path to the ffmpeg binary. Defaults to "ffmpeg" on PATH. End-card stitching
# is skipped gracefully if ffmpeg is unavailable (e.g. Vercel serverless).
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
